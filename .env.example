# ============================================================
# Chat del portafolio — elige UN proveedor de LLM (o ninguno)
#
# Sin ninguna key el chat funciona en MODO DEMO: respuestas
# predefinidas por keywords sobre el contenido, sin LLM.
#
# Opciones (de mejor calidad a 100% gratis):
#   anthropic  → Claude Haiku. La mejor calidad. De pago (centavos/mes
#                con este tráfico). console.anthropic.com
#   groq       → Llama 3.3 70B (open source) servido por Groq.
#                Tier gratuito generoso y muy rápido. console.groq.com
#   openrouter → modelos open source con sufijo ":free".
#                Gratis con límites. openrouter.ai
#   ollama     → LLM open source corriendo en TU máquina (gratis,
#                solo local — no sirve en Vercel). ollama.com
#   demo       → fuerza el modo demo aunque haya keys.
# ============================================================

# Forzar proveedor (opcional). Si se omite, se auto-detecta por la key
# disponible en este orden: anthropic → groq → openrouter → demo.
# Valores: anthropic | groq | openrouter | ollama | demo
CHAT_PROVIDER=

# Sobrescribir el modelo del proveedor elegido (opcional).
# Defaults: claude-haiku-4-5 · llama-3.3-70b-versatile ·
#           meta-llama/llama-3.3-70b-instruct:free · llama3.2
CHAT_MODEL=

# Keys — solo necesitas la del proveedor que uses
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Ollama local (opcional; default http://localhost:11434)
OLLAMA_BASE_URL=

# ============================================================
# Resend — formulario de contacto
# ============================================================
RESEND_API_KEY=
CONTACT_TO_EMAIL=matespinosa09@gmail.com
# Requerido en producción (dominio verificado en Resend). En local puedes usar onboarding@resend.dev
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# Opcional — URLs absolutas para metadata
SITE_URL=http://localhost:3000
